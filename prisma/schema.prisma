generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id
  name        String
  email       String   @unique
  password    String?
  role        String
  status      String   @default("Activo")
  position    String?
  area        String?
  permissions Json?
  payload     Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  auditLogs AuditLog[]

  @@index([email])
  @@index([role])
  @@index([status])
}

model Client {
  id           String   @id
  contactName  String?
  contact      String?
  company      String?
  rut          String?
  phone        String?
  email        String?
  commune      String?
  address      String?
  status       String   @default("Activo")
  observations String?
  payload      Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([rut])
  @@index([company])
  @@index([status])
}

model Quote {
  id          String   @id
  quoteNumber String   @unique
  date        DateTime?
  client      String?
  company     String?
  seller      String?
  subject     String?
  condition   String?
  status      String   @default("Borrador")
  netAmount   Decimal  @default(0) @db.Decimal(14, 2)
  taxAmount   Decimal  @default(0) @db.Decimal(14, 2)
  totalAmount Decimal  @default(0) @db.Decimal(14, 2)
  items       Json?
  payload     Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  financialMovements FinancialMovement[]

  @@index([quoteNumber])
  @@index([status])
  @@index([date])
}

model Document {
  id             String   @id
  type           String
  documentNumber String
  date           DateTime?
  client         String?
  company        String?
  seller         String?
  netAmount      Decimal  @default(0) @db.Decimal(14, 2)
  taxAmount      Decimal  @default(0) @db.Decimal(14, 2)
  totalAmount    Decimal  @default(0) @db.Decimal(14, 2)
  status         String   @default("Borrador")
  origin         String?
  tags           Json?
  observations   String?
  filePdfUrl     String?
  fileExcelUrl   String?
  items          Json?
  payload        Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([type, documentNumber])
  @@index([status])
  @@index([createdAt])
}

model Tender {
  id                         String   @id
  tenderId                   String?  @unique
  title                      String
  buyer                      String?
  buyerRut                   String?
  budget                     Decimal? @db.Decimal(14, 2)
  closingDate                DateTime?
  openingDate                DateTime?
  adjudicationDate           DateTime?
  contractSignDate           DateTime?
  status                     String   @default("Borrador")
  riskLevel                  String   @default("Medio")
  object                     String?
  summary                    String?
  administrativeRequirements Json?
  technicalRequirements      Json?
  economicRequirements       Json?
  requiredDocuments          Json?
  essentialDocuments         Json?
  evaluationCriteria         Json?
  guarantees                 Json?
  paymentTerms               String?
  penalties                  Json?
  risks                      Json?
  suggestedQuestions         Json?
  technicalItems             Json?
  observations               String?
  sourceText                 String?
  sourceFiles                Json?
  fieldSources               Json?
  diagnostics                Json?
  payload                    Json?
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  @@index([status])
  @@index([riskLevel])
  @@index([closingDate])
}

model WorkOrder {
  id             String   @id
  title          String
  type           String
  client         String?
  company        String?
  quoteNumber    String?
  requesterName  String?
  requesterEmail String?
  requesterRole  String?
  assigneeName   String?
  assigneeEmail  String?
  assigneeRole   String?
  sourceArea     String?
  targetArea     String?
  priority       String   @default("Media")
  status         String   @default("Pendiente")
  dueDate        DateTime?
  description    String?
  requirements   String?
  deliverables   String?
  observations   String?
  comments       Json?
  movements      Json?
  payload        Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([status])
  @@index([priority])
  @@index([targetArea])
  @@index([dueDate])
}

model FinancialMovement {
  id                 String   @id
  type               String
  category           String?
  documentType       String?
  documentNumber     String?
  client             String?
  company            String?
  supplierId         String?
  supplierName       String?
  quoteId            String?
  quoteNumber        String?
  tenderId           String?
  workOrderId        String?
  description        String?
  netAmount          Decimal  @default(0) @db.Decimal(14, 2)
  taxRate            Decimal  @default(19) @db.Decimal(5, 2)
  taxAmount          Decimal  @default(0) @db.Decimal(14, 2)
  isTaxExempt        Boolean  @default(false)
  totalAmount        Decimal  @default(0) @db.Decimal(14, 2)
  paidAmount         Decimal  @default(0) @db.Decimal(14, 2)
  pendingAmount      Decimal  @default(0) @db.Decimal(14, 2)
  issueDate          DateTime?
  dueDate            DateTime?
  paymentDate        DateTime?
  status             String   @default("Sin pagar")
  paymentMethod      String?
  paymentTerms       String?
  responsibleName    String?
  responsibleEmail   String?
  observations       String?
  sourceType         String?
  quoteSourceLocked  Boolean  @default(false)
  isAdditionalMovement Boolean @default(false)
  auditLog           Json?
  payload            Json?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  quote    Quote?    @relation(fields: [quoteId], references: [id])
  supplier Supplier? @relation(fields: [supplierId], references: [id])
  payments Payment[]

  @@index([type])
  @@index([status])
  @@index([quoteNumber])
  @@index([dueDate])
}

model Payment {
  id                  String   @id
  financialMovementId String
  amount              Decimal  @db.Decimal(14, 2)
  paymentDate         DateTime @default(now())
  paymentMethod       String?
  reference           String?
  responsibleName     String?
  responsibleEmail    String?
  observations        String?
  auditLog            Json?
  payload             Json?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  financialMovement FinancialMovement @relation(fields: [financialMovementId], references: [id], onDelete: Cascade)

  @@index([financialMovementId])
  @@index([paymentDate])
}

model Supplier {
  id                 String   @id
  name               String
  rut                String?  @unique
  contactName        String?
  phone              String?
  email              String?
  category           String?
  paymentTerms       String?
  bankName           String?
  bankAccountType    String?
  bankAccountNumber  String?
  bankAccountEmail   String?
  status             String   @default("Activo")
  observations       String?
  payload            Json?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  financialMovements FinancialMovement[]

  @@index([name])
  @@index([status])
}

model AuditLog {
  id         String   @id
  module     String
  recordId   String?
  action     String
  userId     String?
  userEmail  String?
  details    Json?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([module])
  @@index([recordId])
  @@index([userEmail])
  @@index([createdAt])
}
