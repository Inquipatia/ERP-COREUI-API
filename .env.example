# Hostinger / Produccion
DATABASE_URL="mysql://USER:PASSWORD@HOST:3306/DATABASE"
CORS_ORIGIN="https://erp.rubikcreaciones.com"
PORT=4300
RUBIK_DATA_ADAPTER=json

# Cambiar a prisma solo despues de migrar y validar /api/health/production-readiness.
# RUBIK_DATA_ADAPTER=prisma

# Desarrollo local
# API_PORT=4300
# CORS_ORIGIN="https://erp.rubikcreaciones.com,http://localhost:4300,http://localhost:5173"

# Pagos demo / sandbox
PAYMENTS_MODE=sandbox
PAYMENT_PROVIDER=sandbox
PAYMENT_SANDBOX_FORCE_STATUS=approved

# Webpay Plus Transbank sandbox
# Para demo Webpay usar PAYMENT_PROVIDER=transbank y TRANSBANK_ENV=integration.
TRANSBANK_ENV=integration
# En integration se usan credenciales oficiales del SDK si estas variables quedan vacias.
# TRANSBANK_COMMERCE_CODE=
# TRANSBANK_API_KEY=
PUBLIC_ERP_URL=https://erp.rubikcreaciones.com
PUBLIC_API_URL=https://api.rubikcreaciones.com/api

# Produccion queda bloqueada salvo configuracion explicita.
# ENABLE_REAL_PAYMENTS=false
